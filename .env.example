# LogEase MCP server configuration
# LOGEASE_BASE_URL=http://127.0.0.1:8090
# Provide either full Authorization header OR API key (user:secret)
# LOGEASE_AUTH_HEADER=apikey admin:YOUR_API_SECRET
# OR
# LOGEASE_API_KEY=admin:xxxx

# TLS settings (optional)
# Set to "true" to enforce strict certificate validation
# Default is "false" to match current development behavior
# LOGEASE_TLS_REJECT_UNAUTHORIZED=false

# HTTP gateway (Streamable HTTP) settings
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=3000
# MCP_HTTP_BASE_PATH=/mcp

# Shared result store (large payloads -> MCP resources)
# LOG_TOOLS_RESULT_STORE_DIR=/tmp/rizhiyi-mcp/log-tool-results
# LOG_TOOLS_RESULT_TTL_SECONDS=1800
# LOG_TOOLS_RESULT_INLINE_MAX_BYTES=24576
# LOG_TOOLS_RESULT_MAX_FILE_BYTES=5242880
